<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRUD Operations</title>
</head>
<body>

    <h1> Update/Delete Quotes </h1>


    <% for (i=0; i < quotes.length; i++) { %>


    <a href="/author/edit?authorId=<%=quotes[i].quoteId%>">UPDATE</a>


    <a href="/author/delete?authorId=<%=quotes[i].quoteId%>">DELETE</a>


    <%=quotes[i].quote%> <br>

    <% } %>
    
    
</body>
</html>